{
  "name": "aretune-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "api": "npm run dev --prefix api",
    "api:build": "npm run build --prefix api",
    "export:web": "expo export --platform web",
    "deploy:test": "npm run export:web && wrangler pages deploy dist --project-name app-aretune --branch preview",
    "deploy:live": "npm run export:web && wrangler pages deploy dist --project-name app-aretune --branch main",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:catalog && npm run test --prefix api",
    "test:catalog": "node api/node_modules/tsx/dist/cli.mjs --test lib/*.test.ts lib/integrations/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@expo/metro-runtime": "~55.0.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.4.18",
    "@supabase/supabase-js": "^2.99.1",
    "ai": "^6.0.116",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.28",
    "expo-constants": "~55.0.17",
    "expo-document-picker": "~55.0.15",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.16",
    "expo-image-picker": "~55.0.22",
    "expo-linking": "~55.0.16",
    "expo-router": "~55.0.17",
    "expo-secure-store": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "victory-native": "^41.20.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2",
    "wrangler": "^4.111.0"
  },
  "private": true
}
